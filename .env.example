# Database
DATABASE_URL=postgres://postgres:root@localhost:5432/ticket_manager

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ACCESS_EXPIRY_HOURS=1
JWT_REFRESH_EXPIRY_DAYS=7

# SMTP (Mailtrap for development)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ticketmanager.dev

# Storage
UPLOAD_DIR=./uploads

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
